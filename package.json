{
  "name": "lightroom-classic-mcp-server",
  "version": "0.1.0",
  "description": "Unofficial MCP server and local bridge for Adobe Lightroom Classic automation.",
  "type": "module",
  "bin": {
    "lightroom-classic-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "lightroom-classic-mcp-server.lrplugin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "mcp",
    "lightroom",
    "lightroom-classic",
    "adobe-lightroom-classic"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.12",
    "eslint": "^9.31.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0"
  },
  "engines": {
    "node": ">=20"
  }
}
